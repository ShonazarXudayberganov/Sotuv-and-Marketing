# ─────────── App ───────────
APP_NAME="NEXUS AI API"
APP_ENV=dev
APP_DEBUG=true

# ─────────── Server ───────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000

# ─────────── Database ───────────
DATABASE_URL=postgresql+asyncpg://nexus:nexus@localhost:5434/nexus_dev
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─────────── Redis ───────────
REDIS_URL=redis://localhost:6379/0

# ─────────── JWT / Security ───────────
# Generate a real secret with: openssl rand -hex 32
JWT_SECRET=change-me-in-production-please-use-a-32-byte-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_MINUTES=60
JWT_REFRESH_TOKEN_TTL_DAYS=30

# ─────────── SMS (Eskiz.uz) ───────────
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_SENDER=4546
SMS_MOCK=true

# ─────────── AI providers (Phase 1) ───────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─────────── OAuth (Phase 0 Sprint 3) ───────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TELEGRAM_BOT_TOKEN=

# ─────────── Rate limiting ───────────
RATE_LIMIT_PER_MINUTE=100

# ─────────── Frontend (apps/web) ───────────
NEXT_PUBLIC_API_URL=http://localhost:8000
